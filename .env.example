# OpenVC scraper — Coolify env template. Set REAL values in Coolify -> Environment
# Variables. Postgres-only (NocoDB is no longer used by the `*-pg` phases).
# Hosts are reachable by CONTAINER NAME on the `coolify` docker network.

# --- Postgres (the `openvc` database — list/detail/formate all read+write here) ---
PG_HOST=yv1n67vj3detg21zejapd0z9   # postgres container name on the coolify network
PG_PORT=5432
PG_DATABASE=openvc
PG_USER=postgres
PG_PASSWORD=CHANGEME

# --- FlareSolverr / byparr (Cloudflare bypass — LIST phase only) ---
# Solves the JS challenge on /search?page=N so the list phase can read it.
FLARESOLVERR_URL=http://v1kvvik5a52gp30gnu6w7kge.159.195.139.150.sslip.io

# --- Detail-phase residential proxies ---
# The DETAIL phase fetches /fund/{slug} through tls-client over residential IPs.
# Provide the pool via a MOUNTED FILE (Coolify -> Persistent Storage -> File Mount)
# at /app/proxies.txt — one `http://user:pass@ip:port` per line. The proxy
# username/password below are also used to build the static proxy list baked into
# scraper.py (override here if the pool rotates).
DETAIL_PROXY_USER=CHANGEME
DETAIL_PROXY_PASS=CHANGEME

# --- Scraper target + tuning knobs (defaults are fine) ---
TOTAL_PAGES=836              # number of /search?page=N list pages to walk
REQUEST_DELAY_MS=2000        # delay between list-page fetches
RESCRAPE_AFTER_HOURS=168     # detail skip-window (NocoDB legacy path only)
FORCE_RESCRAPE=false         # true = ignore skip windows / re-process everything
HTML_CACHE_DIR=html-cache    # where detail HTML is cached (consumed by formate)
